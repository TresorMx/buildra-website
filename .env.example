# Public site URL (used for OG tags and the API). Override per environment.
NEXT_PUBLIC_SITE_URL=https://buildra.mx

# Go High Level — Workflow webhook URL.
# In GHL: Automation → Workflows → Create Workflow → Trigger: "Webhook".
# Copy the inbound URL it generates here. Keep this server-side only.
GHL_WEBHOOK_URL=

# Optional shared secret. If set, requests to the webhook include this in a
# header so you can verify the source inside GHL or a Cloud Function in front.
GHL_WEBHOOK_SECRET=

# WhatsApp number (E.164 format without "+"). Used for floating button + deeplinks.
NEXT_PUBLIC_WHATSAPP_NUMBER=529981543151
NEXT_PUBLIC_PHONE_E164=+529981543151
NEXT_PUBLIC_PHONE_DISPLAY=+52 998 154 3151
NEXT_PUBLIC_EMAIL=hello@buildra.mx

# Social URLs (footer icons). Optional — defaults are placeholders.
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/buildra
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/buildra.mx
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/buildra.mx
